{
  "Desc": "Prometheus is an open-source systems monitoring and alerting toolkit that collects and stores metrics as time series data.",
  "Helm Config": {
    "chart_path": "prometheus/prometheus/",
    "locally": true,
    "namespace": "observe",
    "release_name": "prometheus",
    "values": "prometheus/prometheus/values.yaml"
  },
  "Name": "Prometheus",
  "Namespace": "observe",
  "PersistentVolumeClaimConfig": "prometheus/prometheus-pvc.yml",
  "Supported Operations": [
    "Collect metrics from various endpoints",
    "Store time series data",
    "Query metrics with PromQL",
    "Generate alerts based on metrics"
  ]
}
